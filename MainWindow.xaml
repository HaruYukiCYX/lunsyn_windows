<Window x:Class="lunsyn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="272" Height="520" MinWidth="240" MinHeight="400"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="False"
        Topmost="False" Background="Transparent"
        LocationChanged="Window_LocationChanged">

    <Window.Resources>
        <!-- 主题色 -->
        <Color x:Key="AccentPurple">#8B5CF6</Color>
        <Color x:Key="AccentPink">#EC4899</Color>
        <Color x:Key="AccentBlue">#3B82F6</Color>
        <Color x:Key="AccentGreen">#10B981</Color>
        <Color x:Key="AccentRed">#EF4444</Color>

        <Color x:Key="BgDarker">#0A0612</Color>
        <Color x:Key="BgDark">#0F0A1C</Color>
        <Color x:Key="BgCard">#1A1030</Color>
        <Color x:Key="BgHover">#221840</Color>
        <Color x:Key="BorderSubtle">#2D1F4E</Color>
        <Color x:Key="TextPrimary">#F1F5F9</Color>
        <Color x:Key="TextSecondary">#A5B4FC</Color>
        <Color x:Key="TextMuted">#6B7280</Color>

        <SolidColorBrush x:Key="BgDarkerBrush" Color="{StaticResource BgDarker}"/>
        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>

        <!-- 按钮样式 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#238B5CF6"
                                CornerRadius="6" Padding="12,6"
                                BorderBrush="#338B5CF6" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#358B5CF6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#188B5CF6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#A5B4FC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent"
                                CornerRadius="6" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A8B5CF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent"
                                CornerRadius="6" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AEF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 状态指示圆点 -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <!-- 主容器 -->
    <Border x:Name="MainBorder" CornerRadius="12" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0F0A1C" Offset="0"/>
                <GradientStop Color="#0A0612" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏：可拖拽 -->
            <Border Grid.Row="0" Height="40"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Background="Transparent" Cursor="Hand">
                <Grid Margin="14,0">
                    <TextBlock Text="🌙" FontSize="18" VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="EmojiScale" ScaleX="1" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="TitleText" Text="望月" FontSize="12"
                               FontWeight="SemiBold" Foreground="#C4B5FD"
                               VerticalAlignment="Center" Margin="30,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="PinBtn" Content="📌" FontSize="10" Cursor="Hand"
                                Style="{StaticResource GhostBtn}" Padding="6,4"
                                Click="PinBtn_Click" ToolTip="固定窗口"/>
                        <Button Content="✕" FontSize="10" Cursor="Hand"
                                Style="{StaticResource GhostBtn}" Padding="6,4"
                                Foreground="#94A3B8"
                                Click="CloseBtn_Click" ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,0,12,8">

                    <!-- 状态区 -->
                    <Border Background="{StaticResource BgCardBrush}"
                            CornerRadius="8" BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1" Padding="10,10" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="EmojiText" Text="😴" FontSize="28"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform x:Name="BigEmojiScale" ScaleX="1" ScaleY="1"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="StatusText" Text="灵魂暂时离线..."
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                               MaxWidth="180"/>
                                    <TextBlock x:Name="StatusSubText" Text="望月 · Lunsyn"
                                               FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 我的活动卡片 -->
                    <Border Background="{StaticResource BgCardBrush}"
                            CornerRadius="8" BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1" Padding="10,10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="😶 我的活动" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <StackPanel x:Name="MyActivityPanel"/>
                            <TextBlock x:Name="MyActivityEmpty" Text="等待检测..."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Visibility="Visible"/>
                        </StackPanel>
                    </Border>

                    <!-- 好友活动卡片 -->
                    <Border Background="{StaticResource BgCardBrush}"
                            CornerRadius="8" BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1" Padding="10,10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="❤️ TA 的活动" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#F9A8D4" Margin="0,0,0,8"/>
                            <StackPanel x:Name="FriendActivityPanel"/>
                            <TextBlock x:Name="FriendEmptyText" Text="好友暂未连接"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Visibility="Visible"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Ellipse x:Name="SyncDot" Style="{StaticResource StatusDot}"
                                         Fill="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="SyncStatusLabel" Text="未连接"
                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="SyncBtn" Content="连接" Style="{StaticResource PrimaryBtn}"
                                        Margin="10,0,0,0" Click="SyncBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 屏幕共享卡片 -->
                    <Border Background="{StaticResource BgCardBrush}"
                            CornerRadius="8" BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1" Padding="10,10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="🖥️ 屏幕共享" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Image x:Name="RemoteFrameImage" MaxHeight="120"
                                   Stretch="Uniform" Visibility="Collapsed"
                                   Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="ScreenDot" Style="{StaticResource StatusDot}"
                                         Fill="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="ScreenStatusLabel" Text="未连接"
                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ScreenStartBtn" Content="开始共享"
                                        Style="{StaticResource PrimaryBtn}" Margin="0,0,6,0"
                                        Click="ScreenStartBtn_Click"/>
                                <Button x:Name="ScreenJoinBtn" Content="加入"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#233B82F6" BorderBrush="#333B82F6"
                                        Click="ScreenJoinBtn_Click"/>
                                <Button x:Name="ScreenStopBtn" Content="停止"
                                        Style="{StaticResource DangerBtn}" Margin="0,0,0,0"
                                        Visibility="Collapsed"
                                        Click="ScreenStopBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 分享按钮 -->
                    <Button x:Name="ShareBtn" Content="💬 复制状态"
                            Style="{StaticResource PrimaryBtn}"
                            Background="#2310B981" BorderBrush="#3310B981"
                            HorizontalAlignment="Stretch" Click="ShareBtn_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
