<Window x:Class="lunsyn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="280" Height="540" MinWidth="240" MinHeight="400"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize" ShowInTaskbar="False"
        Topmost="False" Background="#01FFFFFF"
        SourceInitialized="Window_SourceInitialized">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="12"
                      ResizeBorderThickness="4" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Color x:Key="AccentBlue">#3B82F6</Color>
        <Color x:Key="AccentCyan">#06B6D4</Color>
        <Color x:Key="AccentGreen">#10B981</Color>
        <Color x:Key="AccentRed">#EF4444</Color>
        <Color x:Key="TextPrimary">#1E293B</Color>
        <Color x:Key="TextSecondary">#64748B</Color>
        <Color x:Key="TextMuted">#94A3B8</Color>
        <Color x:Key="CardBg">#F8FAFC</Color>
        <Color x:Key="BorderLight">#E2E8F0</Color>

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}"/>
        <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
        <DropShadowEffect x:Key="CardShadowHover" BlurRadius="12" ShadowDepth="0" Opacity="0.10" Color="#000000"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#3B82F6"
                                CornerRadius="6" Padding="10,5"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent"
                                CornerRadius="6" Padding="10,5"
                                BorderBrush="#3B82F6" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0A3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent"
                                CornerRadius="6" Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0A000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="Foreground" Value="#EF4444"/>
        </Style>

        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="7"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
    </Window.Resources>

    <!-- 主容器 -->
    <Border x:Name="MainBorder" CornerRadius="12" ClipToBounds="True"
            Background="#D9F8FAFC" BorderBrush="#40E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Height="36"
                    Background="Transparent"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    MouseMove="Header_MouseMove"
                    MouseLeftButtonUp="Header_MouseLeftButtonUp">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleEmoji" Text="🌙" FontSize="16"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TitleText" Text="望月" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#1E293B"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="PinBtn" Content="📌" FontSize="10"
                                Style="{StaticResource GhostBtn}" Padding="5,3"
                                Click="PinBtn_Click" ToolTip="固定窗口"/>
                        <Button Content="✕" FontSize="10"
                                Style="{StaticResource GhostBtn}" Padding="5,3"
                                Click="CloseBtn_Click" ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="10,0,10,8">

                    <!-- 状态卡片 -->
                    <Border CornerRadius="10" Padding="12,12"
                            Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1" Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="EmojiText" Text="😴" FontSize="32"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="StatusText" Text="灵魂暂时离线..."
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                           MaxWidth="175"/>
                                <TextBlock x:Name="StatusSubText" Text="望月 · Lunsyn"
                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 我的活动 -->
                    <Border CornerRadius="10" Padding="12,12"
                            Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1" Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="📋 我的活动" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <StackPanel x:Name="MyActivityPanel"/>
                            <TextBlock x:Name="MyActivityEmpty" Text="等待检测..."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Visibility="Visible"/>
                        </StackPanel>
                    </Border>

                    <!-- TA 的活动 -->
                    <Border CornerRadius="10" Padding="12,12"
                            Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1" Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="❤️ TA 的活动" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#EC4899" Margin="0,0,0,8"/>
                            <StackPanel x:Name="FriendActivityPanel"/>
                            <TextBlock x:Name="FriendEmptyText" Text="好友暂未连接"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Visibility="Visible"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Ellipse x:Name="SyncDot" Style="{StaticResource StatusDot}"
                                         Fill="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="SyncStatusLabel" Text="未连接"
                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="SyncBtn" Content="连接好友"
                                        Style="{StaticResource PrimaryBtn}" Margin="10,0,0,0"
                                        Click="SyncBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 屏幕共享 -->
                    <Border CornerRadius="10" Padding="12,12"
                            Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1" Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🖥️ 屏幕共享" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Image x:Name="RemoteFrameImage" MaxHeight="120"
                                   Stretch="Uniform" Visibility="Collapsed"
                                   Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="ScreenDot" Style="{StaticResource StatusDot}"
                                         Fill="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="ScreenStatusLabel" Text="未连接"
                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ScreenStartBtn" Content="开始共享"
                                        Style="{StaticResource PrimaryBtn}" Margin="0,0,6,0"
                                        Click="ScreenStartBtn_Click"/>
                                <Button x:Name="ScreenJoinBtn" Content="加入共享"
                                        Style="{StaticResource OutlineBtn}"
                                        Click="ScreenJoinBtn_Click"/>
                                <Button x:Name="ScreenStopBtn" Content="停止"
                                        Style="{StaticResource DangerBtn}" Margin="0,0,0,0"
                                        Visibility="Collapsed"
                                        Click="ScreenStopBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 分享 -->
                    <Button x:Name="ShareBtn" Content="💬 复制状态到剪贴板"
                            Style="{StaticResource PrimaryBtn}"
                            HorizontalAlignment="Stretch"
                            Click="ShareBtn_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
