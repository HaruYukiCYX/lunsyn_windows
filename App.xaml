<Application x:Class="lunsyn.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#7B2FBE"/>
        <SolidColorBrush x:Key="PinkBrush" Color="#E91E8C"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#3B82F6"/>
    </Application.Resources>
</Application>
